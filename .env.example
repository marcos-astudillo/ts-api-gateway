# ─── Server ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ─── PostgreSQL ──────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/api_gateway

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ────────────────────────────────────────────────────
# JWKS endpoint for JWT validation (e.g. Auth0, Keycloak, custom)
JWKS_URI=https://your-auth-provider/.well-known/jwks.json
JWT_AUDIENCE=api-gateway
JWT_ISSUER=https://your-auth-provider/

# Cache JWKS keys for this many seconds before re-fetching
JWKS_CACHE_TTL_SECONDS=600

# ─── Rate Limiting ───────────────────────────────────────────
# Master on/off switch — useful in dev
RATE_LIMIT_ENABLED=true
# Default RPS applied when a route has no explicit policy
RATE_LIMIT_DEFAULT_RPS=100
RATE_LIMIT_DEFAULT_BURST=200

# ─── Features ────────────────────────────────────────────────
FEATURE_CANARY_RELEASES=false
FEATURE_ANALYTICS=false

# ─── Admin API ───────────────────────────────────────────────
# Shared secret used to authenticate calls to /admin/* endpoints
ADMIN_API_KEY=change-me-in-production

# ─── Config Hot Reload ───────────────────────────────────────
# Interval in ms to poll for config version changes
CONFIG_RELOAD_INTERVAL_MS=5000

# ─── Circuit Breaker ─────────────────────────────────────────
CIRCUIT_BREAKER_TIMEOUT_MS=3000
CIRCUIT_BREAKER_ERROR_THRESHOLD_PERCENT=50
CIRCUIT_BREAKER_RESET_TIMEOUT_MS=10000

# ─── Railway (set automatically in Railway deployments) ──────
# RAILWAY_ENVIRONMENT=production
